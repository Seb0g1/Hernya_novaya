# Скопируйте в .env на сервере: cp .env.example .env && nano .env
# Строка подключения PostgreSQL (обязательно для prisma db push и приложения)
DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/DATABASE_NAME"

# NextAuth / Auth.js
AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL="https://ваш-домен.ru"
PUBLIC_APP_URL="https://ваш-домен.ru"

# Шифрование токенов (32 байта в base64)
ENCRYPTION_KEY=

# TikTok (опционально, если не задаёте ключи в форме аккаунта)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Google / YouTube
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Первый админ (seed)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
